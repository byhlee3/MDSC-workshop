# Copy to .env and fill in. Never commit the real .env.
ANTHROPIC_API_KEY=key
ADMIN_PASSWORD=password
MODEL=claude-opus-4-8

# Chat phase tuning. "Continue" unlocks at CHAT_MIN_SECONDS OR
# CHAT_MIN_STUDENT_MESSAGES (whichever comes first).
CHAT_DURATION_SECONDS=480
CHAT_MIN_SECONDS=300
CHAT_MIN_STUDENT_MESSAGES=5

# Frontend dev origin for CORS
FRONTEND_ORIGIN=http://localhost:5173
